{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/push-subscribe", "destination": "/api/push-send" }
  ],
  "headers": [
    {
      "source": "/bugs(.html)?",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/push-send",
      "schedule": "0 12 * * 3"
    },
    {
      "path": "/api/tour?cron=reconcile-payments",
      "schedule": "0 13 * * *"
    }
  ]
}
